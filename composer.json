{
    "name": "edulazaro/laranon",
    "description": "Reversible PII anonymization for Laravel: detect, pseudonymize and restore personal data before it reaches LLMs, logs or third parties. Spanish and English recognizer packs included. Zero dependencies beyond Laravel core.",
    "license": "MIT",
    "type": "library",
    "keywords": ["laravel", "pii", "anonymization", "pseudonymization", "gdpr", "rgpd", "privacy", "llm"],
    "require": {
        "php": ">=8.2",
        "laravel/framework": ">=12.0"
    },
    "autoload": {
        "psr-4": {
            "EduLazaro\\Laranon\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "EduLazaro\\Laranon\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Edu Lazaro",
            "email": "edu@edulazaro.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "EduLazaro\\Laranon\\LaranonServiceProvider"
            ],
            "aliases": {
                "Laranon": "EduLazaro\\Laranon\\Laranon"
            }
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^10.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
